# Maintainer: Osyna <https://github.com/Osyna>
pkgname=oscribe
pkgver=0.1.0
pkgrel=1
pkgdesc='Fast speech-to-text dictation for Linux'
arch=('x86_64')
url='https://github.com/Osyna/Oscribe'
license=('MIT')
depends=('python>=3.10' 'portaudio' 'wl-clipboard' 'wtype' 'ydotool')
makedepends=('python-build' 'python-installer' 'python-hatchling')
optdepends=(
    'xdotool: auto-type on X11'
    'xclip: clipboard on X11'
)
install=oscribe.install
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "Oscribe-$pkgver"
    python -m build --wheel --no-isolation
}

package() {
    cd "Oscribe-$pkgver"
    python -m installer --destdir="$pkgdir" dist/*.whl

    # systemd user service
    install -Dm644 contrib/oscribe.service \
        "$pkgdir/usr/lib/systemd/user/oscribe.service"
    sed -i 's|%h/.local/bin/oscribe|/usr/bin/oscribe|' \
        "$pkgdir/usr/lib/systemd/user/oscribe.service"

    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
